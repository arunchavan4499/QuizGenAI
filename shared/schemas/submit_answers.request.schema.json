{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "submit_answers.request.schema.json",
  "title": "SubmitAnswersRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["quiz_id", "difficulty", "verification_token", "answers"],
  "properties": {
    "quiz_id": {
      "type": "string",
      "minLength": 3
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"]
    },
    "verification_token": {
      "type": "string",
      "minLength": 20
    },
    "answers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question_id", "answer"],
        "properties": {
          "question_id": {
            "type": "string",
            "minLength": 1
          },
          "answer": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
